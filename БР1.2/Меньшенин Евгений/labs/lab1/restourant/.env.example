# Copy this file to `.env` or export the variables in your shell before running the app.
# Do not commit real secret values.

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Optional. Defaults keep using the in-memory H2 database for local development.
DATABASE_URL=jdbc:h2:mem:restaurant;DB_CLOSE_DELAY=-1
DATABASE_DRIVER=org.h2.Driver
DATABASE_USER=sa
DATABASE_PASSWORD=

# Optional Postman value for local collection runs.
USER_PASSWORD=change-me-for-local-tests
